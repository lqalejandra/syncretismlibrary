# Server-only secrets/config for scripts/storage-api-server.mjs
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_PREFIX=uploads
AWS_PRESIGN_EXPIRES_SECONDS=60

# Optional for returned object URLs
AWS_S3_PUBLIC_BASE_URL=
AWS_CLOUDFRONT_URL=

# Optional hardening for the storage API server
STORAGE_API_KEY=
STORAGE_API_ALLOWED_ORIGIN=http://localhost:5173
STORAGE_API_ALLOWED_ORIGINS=http://localhost:5173,https://syncretismlibrary.vercel.app

# Optional migration script variables
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=
MIGRATION_OUTPUT_FILE=s3-migration-map.json
