# Client-safe variables only (Vite exposes VITE_* at build time)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Storage API URL for presigned upload/delete endpoints
VITE_STORAGE_API_BASE_URL=http://localhost:8787

# Optional API key sent to storage API server (not AWS credentials)
VITE_STORAGE_API_KEY=

# Optional image URL bases for rendering S3-hosted images
VITE_AWS_S3_PUBLIC_BASE_URL=
VITE_AWS_CLOUDFRONT_URL=
